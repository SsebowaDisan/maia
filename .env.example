# this is an example .env file, use it to create your own .env file and place it in the root of the project

# database / queue infrastructure
# KH_DATABASE supports sqlite (default) or PostgreSQL, e.g.:
# KH_DATABASE=postgresql+psycopg2://user:password@host:5432/maia
KH_DATABASE=
# optional future queue backend endpoint (reserved for Redis queue workers)
MAIA_REDIS_URL=

# settings for OpenAI
OPENAI_API_BASE=https://api.openai.com/v1
OPENAI_API_KEY=<YOUR_OPENAI_KEY>
OPENAI_CHAT_MODEL=gpt-4o-mini
MAIA_FAST_QA_TEMPERATURE=0.2
MAIA_FAST_QA_SOURCE_SCAN=120
MAIA_FAST_QA_MAX_SOURCES=18
MAIA_FAST_QA_MAX_CHUNKS_PER_SOURCE=3

# Agent LLM Intelligence (set to 0 to disable individual layers)
MAIA_AGENT_LLM_PLANNER_ENABLED=1
MAIA_AGENT_LLM_PLAN_CRITIC_ENABLED=1
MAIA_AGENT_LLM_QUERY_REWRITE_ENABLED=1
MAIA_AGENT_LLM_INTENT_ENABLED=1
MAIA_AGENT_LLM_INTENT_TAGS_ENABLED=1
MAIA_AGENT_LLM_VERIFICATION_ENABLED=1
MAIA_AGENT_LLM_RECOVERY_ENABLED=1
MAIA_AGENT_LLM_EMAIL_POLISH_ENABLED=1
MAIA_AGENT_LLM_CONTACT_POLISH_ENABLED=1
MAIA_AGENT_LLM_RESPONSE_POLISH_ENABLED=1
MAIA_AGENT_LLM_PERSONALIZATION_ENABLED=1
MAIA_AGENT_LLM_CONTEXT_SUMMARY_ENABLED=1
MAIA_AGENT_LLM_STEP_SUMMARY_ENABLED=1
MAIA_AGENT_LLM_TASK_REWRITE_ENABLED=1
MAIA_AGENT_LLM_LOCATION_BRIEF_ENABLED=1
MAIA_AGENT_LLM_TASK_CONTRACT_ENABLED=1
MAIA_AGENT_LLM_DELIVERY_CHECK_ENABLED=1
MAIA_AGENT_LLM_FACT_PROBE_ENABLED=1
# LLM reliability tuning
MAIA_AGENT_LLM_RETRIES=2
MAIA_AGENT_LLM_RETRY_BACKOFF_MS=250
# Comma-separated fallback model list used when the primary model fails
OPENAI_CHAT_MODEL_FALLBACKS=gpt-4.1-mini,gpt-4o-mini
OPENAI_EMBEDDINGS_MODEL=text-embedding-3-large

# settings for Azure OpenAI
AZURE_OPENAI_ENDPOINT=
AZURE_OPENAI_API_KEY=
OPENAI_API_VERSION=2024-02-15-preview
AZURE_OPENAI_CHAT_DEPLOYMENT=gpt-35-turbo
AZURE_OPENAI_EMBEDDINGS_DEPLOYMENT=text-embedding-ada-002

# settings for Cohere
COHERE_API_KEY=<COHERE_API_KEY>

# settings for Mistral
# MISTRAL_API_KEY=placeholder

# settings for VoyageAI
VOYAGE_API_KEY=<VOYAGE_API_KEY>

# settings for Jina web reader / search
JINA_API_KEY=
JINA_URL=https://r.jina.ai/

# settings for web URL crawling
# 0 means unlimited
WEB_READER_MAX_DEPTH=0
WEB_READER_MAX_PAGES=0
WEB_READER_SAME_DOMAIN_ONLY=true
WEB_READER_TIMEOUT=20

# async ingestion jobs (for large batch PDF/URL indexing)
MAIA_INGEST_WORKERS=1
MAIA_INGEST_FILE_BATCH_SIZE=25
MAIA_INGEST_URL_BATCH_SIZE=25
MAIA_INGEST_WORKDIR=.maia_ingestion_jobs
MAIA_INGEST_KEEP_WORKDIR=false

# settings for local models
LOCAL_MODEL=qwen2.5:7b
LOCAL_MODEL_EMBEDDINGS=nomic-embed-text
OLLAMA_BASE_URL=http://127.0.0.1:11434

# settings for GraphRAG
GRAPHRAG_API_KEY=<YOUR_OPENAI_KEY>
GRAPHRAG_LLM_MODEL=gpt-4o-mini
GRAPHRAG_EMBEDDING_MODEL=text-embedding-3-small

# set to true if you want to use customized GraphRAG config file
USE_CUSTOMIZED_GRAPHRAG_SETTING=false

# settings for Azure DI
AZURE_DI_ENDPOINT=
AZURE_DI_CREDENTIAL=

# settings for Adobe API
# get free credential at https://acrobatservices.adobe.com/dc-integration-creation-app-cdn/main.html?api=pdf-extract-api
# also install pip install "pdfservices-sdk@git+https://github.com/niallcm/pdfservices-python-sdk.git@bump-and-unfreeze-requirements"
PDF_SERVICES_CLIENT_ID=
PDF_SERVICES_CLIENT_SECRET=

# settings for PDF.js
PDFJS_VERSION_DIST="pdfjs-4.0.379-dist"

# Maia Company Agent integrations (optional env fallback)
# Prefer storing per-tenant credentials via /api/agent/connectors/credentials.

# Slack
SLACK_BOT_TOKEN=

# Google Ads
GOOGLE_ADS_DEVELOPER_TOKEN=
GOOGLE_ADS_CUSTOMER_ID=
GOOGLE_ADS_LOGIN_CUSTOMER_ID=
GOOGLE_ADS_ACCESS_TOKEN=
GOOGLE_ADS_REFRESH_TOKEN=

# Google Workspace
GOOGLE_WORKSPACE_ACCESS_TOKEN=
GOOGLE_WORKSPACE_REFRESH_TOKEN=

# Microsoft 365
M365_ACCESS_TOKEN=

# Google OAuth 2.0
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
GOOGLE_OAUTH_REDIRECT_URI=http://localhost:8000/api/agent/oauth/google/callback

# Bing Web Search (Azure)
AZURE_BING_API_KEY=
BING_SEARCH_ENDPOINT=https://api.bing.microsoft.com/v7.0/search

# Google Maps (Places / Geocoding / Distance Matrix)
GOOGLE_MAPS_API_KEY=

# Brave Search
BRAVE_SEARCH_API_KEY=

# Gmail API
# Service account DWD (recommended for server-side report sending, no interactive OAuth)
# Preferred: MAIA_GMAIL_SA_JSON_B64 (base64 JSON from secret manager)
# Fallback: MAIA_GMAIL_SA_JSON_PATH (absolute path)
# Never commit raw service-account JSON or private keys.
MAIA_GMAIL_SA_JSON_PATH=
MAIA_GMAIL_SA_JSON_B64=
MAIA_GMAIL_IMPERSONATE=disan@micrurus.com
MAIA_GMAIL_FROM=disan@micrurus.com

# Legacy OAuth token flow (optional)
GMAIL_ACCESS_TOKEN=
GMAIL_REFRESH_TOKEN=
AGENT_GMAIL_PLAYWRIGHT_HEADLESS=true
AGENT_GMAIL_PLAYWRIGHT_SLOW_MO_MS=50
AGENT_GMAIL_PLAYWRIGHT_PROFILE_DIR=.maia_agent/playwright/gmail_profile

# Google Calendar API
GOOGLE_CALENDAR_ACCESS_TOKEN=
GOOGLE_CALENDAR_REFRESH_TOKEN=

# Google Analytics Data API (GA4)
GOOGLE_ANALYTICS_ACCESS_TOKEN=
GOOGLE_ANALYTICS_REFRESH_TOKEN=
GOOGLE_ANALYTICS_PROPERTY_ID=

# Invoice providers
QUICKBOOKS_ACCESS_TOKEN=
QUICKBOOKS_REALM_ID=
XERO_ACCESS_TOKEN=
XERO_TENANT_ID=

# Email verification
EMAIL_VALIDATION_PROVIDER=abstractapi
EMAIL_VALIDATION_API_KEY=

# SMTP
AGENT_SMTP_HOST=
AGENT_SMTP_PORT=587
AGENT_SMTP_USERNAME=
AGENT_SMTP_PASSWORD=

# variable for authentication method selection
# for authentication with google leave empty
# for authentication with keycloak :
# AUTHENTICATION_METHOD="KEYCLOAK"

AUTHENTICATION_METHOD=

# settings for keycloak
KEYCLOAK_SERVER_URL=
KEYCLOAK_CLIENT_ID=
KEYCLOAK_REALM=
KEYCLOAK_CLIENT_SECRET=
